"use client";

import { useEffect, useState, useRef } from "react";
import { useRouter } from "next/navigation";
import { QrCode, X, Zap, Camera, ShieldCheck, Loader2 } from "lucide-react";

export default function QRScanner() {
  const [isOpen, setIsOpen] = useState(false);
  const [isLibLoaded, setIsLibLoaded] = useState(false);
  const [permissionState, setPermissionState] = useState<"idle" | "loading" | "denied">("idle");

  const router = useRouter();
  const scannerRef = useRef<any>(null);

  // ✅ Load Library
  useEffect(() => {
    if (isOpen && !isLibLoaded) {
      const script = document.createElement("script");
      script.src = "https://unpkg.com/html5-qr-code";
      script.async = true;
      script.onload = () => setIsLibLoaded(true);
      document.body.appendChild(script);
    }
  }, [isOpen, isLibLoaded]);

  // ✅ Check Camera Permission
  const checkPermission = async () => {
    try {
      setPermissionState("loading");

      await navigator.mediaDevices.getUserMedia({ video: true });

      setPermissionState("idle");
      startScanner();
    } catch (err) {
      setPermissionState("denied");
    }
  };

  // ✅ Start Scanner
  const startScanner = () => {
    try {
      // @ts-ignore
      const html5QrCode = new window.Html5QrcodeScanner(
        "reader",
        { fps: 10, qrbox: { width: 250, height: 250 } },
        false
      );

      html5QrCode.render(
        (decodedText: string) => {
          html5QrCode.clear();
          setIsOpen(false);
          router.push(`/request/${decodedText}`);
        },
        () => {}
      );

      scannerRef.current = html5QrCode;
    } catch (err) {
      console.error("Scanner error", err);
    }
  };

  // Cleanup
  useEffect(() => {
    return () => {
      if (scannerRef.current) {
        scannerRef.current.clear().catch(() => {});
      }
    };
  }, []);

  return (
    <div className="w-full">
      <button
        onClick={() => setIsOpen(true)}
        className="w-full py-6 bg-slate-900 text-white rounded-[2.5rem] font-[1000] flex items-center justify-center gap-4"
      >
        <QrCode size={20} />
        Scan Device QR
      </button>

      {isOpen && (
        <div className="fixed inset-0 z-[2000] bg-black/40 flex items-center justify-center p-4">
          <div className="w-full max-w-md bg-white rounded-3xl shadow-xl overflow-hidden">

            {/* Header */}
            <div className="p-6 flex justify-between items-center">
              <div className="flex items-center gap-3">
                <Camera />
                <h2 className="font-bold">QR Scanner</h2>
              </div>
              <button onClick={() => setIsOpen(false)}>
                <X />
              </button>
            </div>

            {/* Scanner Area */}
            <div className="p-4 text-center">

              {permissionState === "idle" && !isLibLoaded && (
                <Loader2 className="animate-spin mx-auto" />
              )}

              {/* Start Button */}
              {permissionState === "idle" && isLibLoaded && (
                <button
                  onClick={checkPermission}
                  className="px-5 py-3 bg-blue-600 text-white rounded-xl"
                >
                  Start Scanner
                </button>
              )}

              {/* Loading */}
              {permissionState === "loading" && (
                <div>
                  <Loader2 className="animate-spin mx-auto mb-2" />
                  <p>Requesting Camera Permission...</p>
                </div>
              )}

              {/* Denied */}
              {permissionState === "denied" && (
                <div className="text-red-500">
                  ❌ Camera Blocked <br />
                  <p className="text-sm mt-2">
                    Enable from browser settings:
                  </p>
                  <div className="text-xs mt-2 bg-gray-100 p-2 rounded">
                    🔒 Click URL lock → Allow Camera
                  </div>

                  <button
                    onClick={checkPermission}
                    className="mt-3 px-4 py-2 bg-black text-white rounded"
                  >
                    Retry
                  </button>
                </div>
              )}

              {/* Scanner Render */}
              <div id="reader" className="mt-4"></div>
            </div>

            {/* Footer */}
            <div className="p-4 text-center text-xs text-gray-400 flex items-center justify-center gap-2">
              <ShieldCheck size={12} />
              Secure Scan
            </div>
          </div>
        </div>
      )}
    </div>
  );
}