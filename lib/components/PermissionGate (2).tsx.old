"use client";

import { useState, useEffect, useCallback } from "react";
import { 
  ShieldAlert, 
  MapPin, 
  Camera, 
  Settings2, 
  X, 
  Check, 
  Copy, 
  MousePointer2, 
  ExternalLink, 
  RefreshCcw,
  Zap,         // ✅ Added missing import
  ArrowRight,  // ✅ Added missing import
  ShieldCheck  // ✅ Added missing import
} from "lucide-react";

export default function PermissionGate() {
  const [status, setStatus] = useState({ location: "prompt", camera: "prompt" });
  const [isOpen, setIsOpen] = useState(false);
  const [copied, setCopied] = useState(false);

  // 1. Scanner Logic
  const scanPermissions = useCallback(async () => {
    if (typeof window === "undefined" || !navigator.permissions) return;
    try {
      const [locStatus, camStatus] = await Promise.all([
        navigator.permissions.query({ name: "geolocation" as PermissionName }),
        navigator.permissions.query({ name: "camera" as PermissionName })
      ]);
      setStatus({
        location: locStatus.state,
        camera: camStatus.state,
      });
      locStatus.onchange = () => setStatus(p => ({ ...p, location: locStatus.state }));
      camStatus.onchange = () => setStatus(p => ({ ...p, camera: camStatus.state }));
    } catch (err) {
      console.warn("Permission scan failed", err);
    }
  }, []);

  useEffect(() => { scanPermissions(); }, [scanPermissions]);

  // 2. Action Handlers
  const handleAction = (type: 'location' | 'camera') => {
    if (type === 'location') {
      navigator.geolocation.getCurrentPosition(
        () => setStatus(p => ({ ...p, location: "granted" })),
        () => setStatus(p => ({ ...p, location: "denied" })),
        { enableHighAccuracy: true, timeout: 5000 }
      );
    } else {
      navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment" } })
        .then(stream => {
          stream.getTracks().forEach(t => t.stop());
          setStatus(p => ({ ...p, camera: "granted" }));
        })
        .catch(() => setStatus(p => ({ ...p, camera: "denied" })));
    }
  };

  const copySettingsLink = () => {
    const settingsUrl = `chrome://settings/content/siteDetails?site=${encodeURIComponent(window.location.origin)}`;
    navigator.clipboard.writeText(settingsUrl);
    setCopied(true);
    setTimeout(() => setCopied(false), 3000);
  };

  const allClear = status.location === "granted" && status.camera === "granted";
  
  // Sab permissions sahi hain toh screen clean rakho
  if (allClear) return null;

  return (
    <>
      {/* 🚨 Floating Trigger Button: Smooth Hover Expansion */}
<button 
  onClick={() => setIsOpen(true)} 
  className="fixed bottom-6 right-6 z-[999] bg-red-600 text-white p-4 rounded-[25px] shadow-[0_20px_50px_rgba(220,38,38,0.4)] animate-bounce border-4 border-white flex items-center gap-0 hover:gap-3 group transition-all duration-500 ease-in-out active:scale-90 hover:scale-110"
>
  {/* Icon size slightly adjusted for better alignment */}
  <ShieldAlert size={26} className="shrink-0" />
  
  {/* Text jo hover karne par bahar aayega */}
  <span className="text-[11px] font-[1000] uppercase tracking-[2px] overflow-hidden max-w-0 group-hover:max-w-[120px] transition-all duration-500 ease-in-out whitespace-nowrap italic">
    Fix Access
  </span>

  {/* Notification dot (Chota sa extra touch) */}
  <span className="absolute -top-1 -right-1 flex h-4 w-4">
    <span className="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
    <span className="relative inline-flex rounded-full h-4 w-4 bg-red-500 border-2 border-white"></span>
  </span>
</button>


      {/* 🎴 Modal Overlay */}
      {isOpen && (
        <div className="fixed inset-0 z-[1000] bg-slate-900/40 backdrop-blur-md flex items-center justify-center p-4 animate-in fade-in duration-300 font-sans text-left">
          <div className="w-full max-w-[420px] bg-white rounded-[3rem] shadow-2xl border border-white animate-in zoom-in-95 p-8 relative">
            
            <div className="flex justify-between items-center mb-8">
              <div className="bg-slate-900 p-3 rounded-2xl text-blue-400">
                <Settings2 size={24} />
              </div>
              <button onClick={() => setIsOpen(false)} className="text-slate-300 hover:text-slate-900 transition-colors">
                <X size={24} />
              </button>
            </div>

            <h2 className="text-2xl font-[1000] text-slate-900 uppercase italic tracking-tighter mb-8 leading-none">
              Hardware <br/> Authentication
            </h2>

            {/* --- Status Cards (Aapka Image Design) --- */}
            <div className="space-y-4">
              <StatusCard 
                label="LOCATION (GPS)" 
                status={status.location} 
                icon={<MapPin size={20}/>} 
                onEnable={() => handleAction('location')}
              />
              <StatusCard 
                label="SCANNER (CAMERA)" 
                status={status.camera} 
                icon={<Camera size={20}/>} 
                onEnable={() => handleAction('camera')}
              />
            </div>

            {/* --- Block Guide --- */}
            {(status.location === "denied" || status.camera === "denied") && (
              <div className="mt-8 p-6 bg-red-50 rounded-[2.5rem] border border-red-100 animate-in slide-in-from-top-2">
                <p className="text-[10px] font-black text-red-400 uppercase mb-4 italic tracking-widest text-center">Fixing Steps Below:</p>
                
                <div className="space-y-3 mb-6">
                  <div className="flex gap-3 items-center text-[11px] font-bold text-slate-700">
                    <span className="bg-red-200 text-red-700 w-5 h-5 rounded-full flex items-center justify-center text-[9px] shrink-0 font-black italic">1</span>
                    <p>URL bar mein <span className="text-blue-600 font-black italic underline">Lock (🔒)</span> ko dabayein.</p>
                  </div>
                  <div className="flex gap-3 items-center text-[11px] font-bold text-slate-700">
                    <span className="bg-red-200 text-red-700 w-5 h-5 rounded-full flex items-center justify-center text-[9px] shrink-0 font-black italic">2</span>
                    <p><span className="underline italic">Site Settings</span> {'>'} <span className="underline italic">Permissions</span>.</p>
                  </div>
                  <div className="flex gap-3 items-center text-[11px] font-bold text-slate-700">
                    <span className="bg-red-200 text-red-700 w-5 h-5 rounded-full flex items-center justify-center text-[9px] shrink-0 font-black italic">3</span>
                    <p><span className="text-emerald-600 font-black italic underline">Allow</span> Location & Camera.</p>
                  </div>
                </div>

                <div className="bg-white/60 p-4 rounded-2xl border border-red-100/50 mb-4 shadow-inner">
                  <div onClick={copySettingsLink} className="flex items-center justify-between bg-white border border-slate-200 px-3 py-2 rounded-xl cursor-pointer hover:border-blue-300 transition-colors">
                    <p className="text-[9px] font-mono text-slate-400 truncate">chrome://settings/content...</p>
                    {copied ? <Check size={12} className="text-emerald-500" /> : <Copy size={12} className="text-slate-400" />}
                  </div>
                  {copied && (
                    <div className="mt-2 space-y-1">
                      <p className="text-[8px] font-black text-blue-600 uppercase flex items-center gap-1 animate-in fade-in"><MousePointer2 size={10}/> New Tab kholiye</p>
                      <p className="text-[8px] font-black text-blue-600 uppercase flex items-center gap-1 animate-in fade-in"><ExternalLink size={10}/> Paste karke Enter karein</p>
                    </div>
                  )}
                </div>

                <button onClick={() => window.location.reload()} className="w-full py-4 bg-red-600 text-white rounded-2xl font-black text-[11px] uppercase flex items-center justify-center gap-2 active:scale-95 transition-all shadow-lg italic">
                  <RefreshCcw size={14} /> Refresh System
                </button>
              </div>
            )}

            <button 
              disabled={!allClear}
              onClick={() => setIsOpen(false)}
              className={`w-full mt-6 py-6 rounded-[2.5rem] font-black uppercase tracking-[0.2em] flex items-center justify-center gap-3 transition-all duration-500 shadow-xl ${
                allClear ? 'bg-blue-600 text-white scale-100 shadow-blue-200' : 'bg-slate-100 text-slate-300 scale-95 cursor-not-allowed'
              }`}
            >
              {allClear ? (
                <>Ready to Enter <ArrowRight size={20}/></>
              ) : (
                <>Awaiting Auth <Zap className="animate-pulse" size={18}/></>
              )}
            </button>
          </div>
        </div>
      )}
    </>
  );
}

// Internal Component for Status Cards
function StatusCard({ label, status, icon, onEnable }: any) {
  const isGranted = status === "granted";
  const isDenied = status === "denied";

  return (
    <div className={`p-1 rounded-[2.5rem] transition-all duration-500 ${isGranted ? 'bg-emerald-50 border border-emerald-100' : 'bg-[#F8FAFC] border border-slate-100'}`}>
      <div className="flex items-center justify-between p-4 bg-white rounded-[2.3rem] shadow-sm">
        <div className="flex items-center gap-4">
          <div className={`p-3 rounded-2xl ${isGranted ? 'bg-emerald-500 text-white' : 'bg-slate-100 text-slate-400'}`}>
            {icon}
          </div>
          <div className="text-left">
            <p className="text-[9px] font-black text-slate-400 uppercase tracking-tighter leading-none mb-1 italic">{label}</p>
            <p className={`text-xs font-[1000] italic uppercase tracking-tighter ${isGranted ? 'text-emerald-600' : 'text-slate-700'}`}>
              {isGranted ? '✓ FULL ACCESS' : isDenied ? '✕ BLOCKED' : 'READY TO AUTH'}
            </p>
          </div>
        </div>
        {!isGranted && (
          <button 
            onClick={onEnable}
            className="bg-[#111827] text-white px-6 py-2.5 rounded-2xl text-[10px] font-[1000] uppercase italic tracking-widest active:scale-90 transition-all shadow-md"
          >
            Enable
          </button>
        )}
      </div>
    </div>
  );
}